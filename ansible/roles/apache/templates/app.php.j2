<?php
$server_id = getenv('SERVER_ID') ?: '{{ server_id }}';
$db_config = [
    'host'     => '{{ db_host }}',
    'port'     => '{{ db_port }}',
    'dbname'   => '{{ db_name }}',
    'user'     => '{{ db_user }}',
    'password' => '{{ db_password }}',
];

$db_status = 'Non connecté';
$visits    = [];
$message   = '';
$total     = 0;

try {
    $dsn = "pgsql:host={$db_config['host']};port={$db_config['port']};dbname={$db_config['dbname']}";
    $pdo = new PDO($dsn, $db_config['user'], $db_config['password'], [
        PDO::ATTR_ERRMODE => PDO::ERRMODE_EXCEPTION,
    ]);

    $pdo->prepare("INSERT INTO visits (server_id, ip_address) VALUES (?, ?)")
        ->execute([$server_id, $_SERVER['REMOTE_ADDR'] ?? 'unknown']);

    $message = $pdo->query("SELECT content FROM messages ORDER BY id LIMIT 1")
                   ->fetchColumn();

    $visits = $pdo->query("SELECT server_id, COUNT(*) as total FROM visits GROUP BY server_id ORDER BY server_id")
                  ->fetchAll(PDO::FETCH_ASSOC);

    $total = $pdo->query("SELECT COUNT(*) FROM visits")->fetchColumn();

    $db_status = 'Connecté à PostgreSQL ' . $db_config['host'];

} catch (PDOException $e) {
    $db_status = 'Erreur : ' . $e->getMessage();
}
?>
